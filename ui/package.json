{
  "name": "yz-iris-ui",
  "private": true,
  "version": "0.0.4",
  "type": "module",
  "description": "Iris satellite UI — shipped as react-dynamic-module IIFE for JarvYZ, also buildable as a standalone SPA.",
  "scripts": {
    "dev": "vite",
    "build:lib": "vite build --mode lib",
    "build:pages": "vite build --mode pages && node scripts/copy-mp-assets.mjs",
    "install-to-frontend": "node scripts/install-to-frontend.mjs",
    "ship": "npm run build:lib && npm run install-to-frontend"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@mui/icons-material": "^9.1.2",
    "@mui/material": "^9.1.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.10"
  }
}
